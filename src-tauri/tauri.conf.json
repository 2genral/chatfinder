{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Chatfinder",
  "version": "0.1.0",
  "identifier": "io.github.2genral.chatfinder",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Chatfinder",
        "width": 1120,
        "height": 720,
        "minWidth": 820,
        "minHeight": 560,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "shortDescription": "Search Claude Code and Codex chats locally.",
    "longDescription": "A fast, private desktop search tool for local Claude Code and Codex conversation history.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
